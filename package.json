{
  "name": "ramakirti-foundation-web",
  "version": "1.0.0",
  "description": "Modern, high-conversion NGO website for Ramakirti Foundation",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "node_modules/.bin/prisma generate && next build",
    "start": "next start",
    "lint": "next lint --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "jest",
    "test:e2e": "playwright test",
    "analyze": "ANALYZE=true next build",
    "lighthouse": "lighthouse https://localhost:3000 --view"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@portabletext/react": "^3.0.11",
    "@prisma/client": "^5.10.1",
    "@sanity/client": "^6.11.0",
    "@sanity/image-url": "^1.0.2",
    "@sentry/nextjs": "^7.98.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "autoprefixer": "^10.4.18",
    "axios": "^1.6.8",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.3.0",
    "dotenv": "^16.4.5",
    "framer-motion": "^10.16.16",
    "html2pdf.js": "^0.10.1",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.378.0",
    "next": "^14.2.0",
    "next-sanity": "^5.5.10",
    "nodemailer": "^6.9.10",
    "pdfkit": "^0.13.0",
    "postcss": "^8.4.36",
    "prisma": "^5.10.1",
    "razorpay": "^2.9.2",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.51.3",
    "react-icons": "^5.7.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^14.2.0",
    "@playwright/test": "^1.41.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.2.0",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.15",
    "@types/pdfkit": "^0.13.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "jest": "^29.7.0",
    "playwright": "^1.41.0",
    "prettier": "^3.2.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "ngo",
    "nextjs",
    "tailwind",
    "donation",
    "volunteer",
    "education",
    "charity"
  ],
  "author": "Ramakirti Foundation Development Team",
  "license": "MIT"
}
