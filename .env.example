# =========================================================================
# RAMAKIRTI FOUNDATION — PRODUCTION ENVIRONMENT VARIABLES CONFIGURATION
# Copy this file to .env.local for local development:
# cp .env.example .env.local
# =========================================================================

# 1. DATABASE CONFIGURATION (PostgreSQL)
# Get a free serverless database URL from Neon.tech or Railway.app
DATABASE_URL="postgresql://user:password@hostname:5432/ramakirti?sslmode=require"

# 2. RAZORPAY PAYMENT GATEWAY (UPI-first Indian payment processor)
# Create a free merchant account on https://razorpay.com/ and obtain keys in Test/Live mode
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_XXXXXXXXXXXXXXXX"
RAZORPAY_KEY_SECRET="XXXXXXXXXXXXXXXXXXXXXXXX"

# 3. EMAIL SMTP SERVICE (SMTP/Gmail for automated 80G tax receipt delivery)
# For Gmail: Generate an "App Password" in Google Account -> Security -> 2-Step Verification -> App Passwords
EMAIL_USER="support@ramakirtifoundation.co.in"
EMAIL_PASSWORD="xxxx xxxx xxxx xxxx"

# 4. WHATSAPP CONFIRMATIONS VIA TWILIO (Optional)
# Get credentials on https://www.twilio.com/ console
TWILIO_ACCOUNT_SID="ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
TWILIO_AUTH_TOKEN="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
TWILIO_WHATSAPP_NUMBER="+14155238886" # The sandbox or registered Twilio number
